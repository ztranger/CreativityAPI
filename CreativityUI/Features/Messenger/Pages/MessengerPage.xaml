<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewModels="clr-namespace:CreativityUI.Features.Messenger.ViewModels"
             x:Class="CreativityUI.Features.Messenger.Pages.MessengerPage"
             x:DataType="viewModels:MessengerViewModel"
             Title="Messenger">

    <ContentPage.Resources>
        <Color x:Key="SidebarBg">#F8F8F8</Color>
        <Color x:Key="SelectedChatBg">#3A8CCE</Color>
        <Color x:Key="SelectedChatText">#FFFFFF</Color>
        <Color x:Key="MessageAreaBg">#DDEED9</Color>
        <Color x:Key="IncomingBubbleBg">#FFFFFF</Color>
        <Color x:Key="OutgoingBubbleBg">#D9FDD3</Color>
        <Color x:Key="MutedText">#76808A</Color>

        <Style x:Key="AvatarCircleStyle" TargetType="Border">
            <Setter Property="WidthRequest" Value="42" />
            <Setter Property="HeightRequest" Value="42" />
            <Setter Property="StrokeShape">
                <Setter.Value>
                    <RoundRectangle CornerRadius="21" />
                </Setter.Value>
            </Setter>
            <Setter Property="BackgroundColor" Value="#B8C8D6" />
            <Setter Property="StrokeThickness" Value="0" />
        </Style>

        <DataTemplate x:Key="ChatItemTemplate" x:DataType="viewModels:ChatListItemViewModel">
            <Border StrokeThickness="0"
                    Padding="10,8"
                    Margin="6,2"
                    BackgroundColor="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="10" />
                </Border.StrokeShape>
                <Border.Triggers>
                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                        <Setter Property="BackgroundColor" Value="{StaticResource SelectedChatBg}" />
                    </DataTrigger>
                </Border.Triggers>

                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="10">
                    <Border Style="{StaticResource AvatarCircleStyle}">
                        <Label HorizontalOptions="Center"
                               VerticalOptions="Center"
                               Text="{Binding AvatarInitials}"
                               FontAttributes="Bold"
                               TextColor="White" />
                    </Border>

                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="{Binding Title}"
                               FontAttributes="Bold"
                               LineBreakMode="TailTruncation">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="TextColor" Value="{StaticResource SelectedChatText}" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Label Text="{Binding Subtitle}"
                               FontSize="12"
                               LineBreakMode="TailTruncation"
                               TextColor="{StaticResource MutedText}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="TextColor" Value="#D6EBFF" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                    </VerticalStackLayout>

                    <VerticalStackLayout Grid.Column="2"
                                         HorizontalOptions="End"
                                         Spacing="4">
                        <Label Text="{Binding TimeText}"
                               FontSize="11"
                               HorizontalTextAlignment="End"
                               TextColor="{StaticResource MutedText}">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label" Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="TextColor" Value="#D6EBFF" />
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>
                        <Border IsVisible="{Binding HasUnread}"
                                HorizontalOptions="End"
                                StrokeThickness="0"
                                BackgroundColor="#68BA52"
                                Padding="6,1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>
                            <Label Text="{Binding UnreadCount}"
                                   FontSize="11"
                                   TextColor="White" />
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="MessageItemTemplate" x:DataType="viewModels:MessageItemViewModel">
            <Grid Margin="8,3">
                <Border
                        IsVisible="{Binding IsIncoming}"
                        HorizontalOptions="Start"
                        MaximumWidthRequest="{OnIdiom Phone=320, Tablet=560, Desktop=900}"
                        BackgroundColor="{StaticResource IncomingBubbleBg}"
                        StrokeThickness="0"
                        Padding="10,7">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="3">
                        <Label Text="{Binding SenderCaption}"
                               FontAttributes="Bold"
                               FontSize="12"
                               TextColor="#4D6F8D" />
                        <Label Text="{Binding Message.Text}" LineBreakMode="WordWrap" />
                        <Label Text="{Binding TimeText}"
                               FontSize="11"
                               HorizontalTextAlignment="End"
                               TextColor="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                </Border>

                <Border
                        IsVisible="{Binding IsOutgoing}"
                        HorizontalOptions="End"
                        MaximumWidthRequest="{OnIdiom Phone=320, Tablet=560, Desktop=900}"
                        BackgroundColor="{StaticResource OutgoingBubbleBg}"
                        StrokeThickness="0"
                        Padding="10,7">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="3">
                        <Label Text="{Binding Message.Text}"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="End" />
                        <Label Text="{Binding TimeText}"
                               FontSize="11"
                               HorizontalTextAlignment="End"
                               TextColor="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid BackgroundColor="#D3D8DD">
        <Grid IsVisible="{OnIdiom Phone=False, Default=True}"
              Padding="0"
              ColumnDefinitions="335,*">
            <Grid Grid.Column="0"
                  BackgroundColor="{StaticResource SidebarBg}"
                  RowDefinitions="Auto,Auto,*">
                <Grid Grid.Row="0"
                      Padding="10,8"
                      ColumnDefinitions="Auto,*"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="+"
                            WidthRequest="40"
                            HeightRequest="40"
                            CornerRadius="20"
                            FontSize="24"
                            BackgroundColor="#4FA5E2"
                            TextColor="White"
                            Command="{Binding CreateChatCommand}" />
                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="#ECECEC"
                            Padding="12,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Search"
                               Text="{Binding SearchQuery}"
                               BackgroundColor="Transparent"
                               ClearButtonVisibility="WhileEditing" />
                    </Border>
                </Grid>

                <Label Grid.Row="1"
                       Margin="14,4,14,4"
                       Text="{Binding StatusMessage}"
                       FontSize="11"
                       TextColor="{StaticResource MutedText}" />

                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding ChatItems}"
                                SelectedItem="{Binding SelectedChatItem, Mode=TwoWay}"
                                ItemTemplate="{StaticResource ChatItemTemplate}"
                                SelectionMode="Single" />
            </Grid>

            <Grid Grid.Column="1"
                  RowDefinitions="Auto,*,Auto"
                  BackgroundColor="{StaticResource MessageAreaBg}">
                <Grid Grid.Row="0"
                      BackgroundColor="#F2F3F5"
                      Padding="14,10"
                      ColumnDefinitions="Auto,*,Auto,Auto,Auto"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="&#x276E;"
                            FontSize="18"
                            BackgroundColor="Transparent" />
                    <VerticalStackLayout Grid.Column="1" Spacing="2">
                        <Label Text="{Binding SelectedChatTitle}"
                               FontAttributes="Bold"
                               FontSize="17" />
                        <Label Text="{Binding SelectedChatSubtitle}"
                               FontSize="12"
                               TextColor="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="2" Text="&#x1F50D;" BackgroundColor="Transparent" />
                    <Button Grid.Column="3" Text="&#x260E;" BackgroundColor="Transparent" />
                    <Button Grid.Column="4" Text="&#x22EE;" BackgroundColor="Transparent" />
                </Grid>

                <CollectionView Grid.Row="1"
                                Margin="4,6"
                                ItemsSource="{Binding MessageItems}"
                                ItemTemplate="{StaticResource MessageItemTemplate}"
                                SelectionMode="None" />

                <Grid Grid.Row="2"
                      BackgroundColor="#F2F3F5"
                      Padding="10,8"
                      ColumnDefinitions="Auto,*,Auto"
                      ColumnSpacing="8">
                    <Button Grid.Column="0"
                            Text="&#x1F4CE;"
                            BackgroundColor="Transparent"
                            FontSize="20" />
                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            BackgroundColor="White"
                            Padding="12,8">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="20" />
                        </Border.StrokeShape>
                        <Entry Placeholder="Write a message..."
                               Text="{Binding DraftMessage}"
                               ReturnType="Send"
                               ReturnCommand="{Binding SendMessageCommand}"
                               BackgroundColor="Transparent" />
                    </Border>
                    <Button Grid.Column="2"
                            Text="Send"
                            Command="{Binding SendMessageCommand}"
                            BackgroundColor="#4FA5E2"
                            TextColor="White"
                            Padding="14,8" />
                </Grid>
            </Grid>
        </Grid>

        <Grid IsVisible="{OnIdiom Phone=True, Default=False}"
              Padding="0"
              RowDefinitions="Auto,*,*"
              BackgroundColor="{StaticResource MessageAreaBg}">
            <Grid Grid.Row="0"
                  BackgroundColor="{StaticResource SidebarBg}"
                  Padding="10,8"
                  ColumnDefinitions="Auto,*,Auto"
                  ColumnSpacing="8">
                <Button Grid.Column="0"
                        Text="+"
                        WidthRequest="36"
                        HeightRequest="36"
                        CornerRadius="18"
                        Command="{Binding CreateChatCommand}"
                        BackgroundColor="#4FA5E2"
                        TextColor="White" />
                <Border Grid.Column="1"
                        StrokeThickness="0"
                        BackgroundColor="#ECECEC"
                        Padding="10,6">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Entry Placeholder="Search"
                           Text="{Binding SearchQuery}"
                           BackgroundColor="Transparent" />
                </Border>
                <Label Grid.Column="2"
                       VerticalTextAlignment="Center"
                       FontSize="20"
                       Text="&#x2630;" />
            </Grid>

            <CollectionView Grid.Row="1"
                            BackgroundColor="{StaticResource SidebarBg}"
                            ItemsSource="{Binding ChatItems}"
                            SelectedItem="{Binding SelectedChatItem, Mode=TwoWay}"
                            ItemTemplate="{StaticResource ChatItemTemplate}"
                            SelectionMode="Single" />

            <Grid Grid.Row="2"
                  RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0"
                      BackgroundColor="#F2F3F5"
                      Padding="12,8">
                    <VerticalStackLayout Spacing="1">
                        <Label Text="{Binding SelectedChatTitle}"
                               FontAttributes="Bold"
                               FontSize="16" />
                        <Label Text="{Binding SelectedChatSubtitle}"
                               FontSize="11"
                               TextColor="{StaticResource MutedText}" />
                    </VerticalStackLayout>
                </Grid>

                <CollectionView Grid.Row="1"
                                ItemsSource="{Binding MessageItems}"
                                ItemTemplate="{StaticResource MessageItemTemplate}"
                                SelectionMode="None" />

                <Grid Grid.Row="2"
                      BackgroundColor="#F2F3F5"
                      Padding="8,6"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Write a message..."
                           Text="{Binding DraftMessage}"
                           ReturnType="Send"
                           ReturnCommand="{Binding SendMessageCommand}" />
                    <Button Grid.Column="1"
                            Text="Send"
                            Command="{Binding SendMessageCommand}" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
