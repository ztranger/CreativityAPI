<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:chats="clr-namespace:API.Contracts.Chats;assembly=API.Contracts"
             xmlns:viewModels="clr-namespace:CreativityUI.Features.Messenger.ViewModels"
             x:Class="CreativityUI.Features.Messenger.Pages.MessengerPage"
             x:DataType="viewModels:MessengerViewModel"
             Title="Messenger">

    <Grid Padding="16"
          ColumnDefinitions="320,*"
          RowDefinitions="Auto,*">
        <Button Grid.Row="0"
                Grid.Column="0"
                Margin="0,0,12,12"
                Text="Новый чат"
                Command="{Binding CreateChatCommand}" />

        <Border Grid.Row="1"
                Grid.Column="0"
                Margin="0,0,12,0"
                StrokeThickness="1"
                Padding="8">
            <CollectionView ItemsSource="{Binding Chats}"
                            SelectionMode="Single"
                            SelectedItem="{Binding SelectedChat, Mode=TwoWay}">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="chats:ChatSummaryResponse">
                        <VerticalStackLayout Padding="8,10" Spacing="4">
                            <Label Text="{Binding Title}"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Description}"
                                   FontSize="12"
                                   TextColor="Gray"
                                   LineBreakMode="TailTruncation" />
                        </VerticalStackLayout>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Border Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="1"
                StrokeThickness="1"
                Padding="12">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <Label Grid.Row="0"
                       Text="{Binding SelectedChatTitle}"
                       FontSize="22"
                       FontAttributes="Bold" />

                <Label Grid.Row="1"
                       Margin="0,6,0,10"
                       Text="{Binding StatusMessage}"
                       FontSize="12"
                       TextColor="Gray" />

                <CollectionView Grid.Row="2"
                                ItemsSource="{Binding Messages}"
                                SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="chats:MessageResponse">
                            <VerticalStackLayout Padding="6,8" Spacing="4">
                                <Label Text="{Binding SenderUserId, StringFormat='User #{0}'}"
                                       FontAttributes="Bold"
                                       FontSize="12" />
                                <Label Text="{Binding Text}"
                                       LineBreakMode="WordWrap" />
                                <Label Text="{Binding CreatedAt, StringFormat='{0:g}'}"
                                       FontSize="11"
                                       TextColor="Gray" />
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

                <Grid Grid.Row="3"
                      Margin="0,10,0,0"
                      ColumnDefinitions="*,Auto"
                      ColumnSpacing="8">
                    <Entry Grid.Column="0"
                           Placeholder="Введите сообщение"
                           Text="{Binding DraftMessage}"
                           ReturnType="Send"
                           ReturnCommand="{Binding SendMessageCommand}" />
                    <Button Grid.Column="1"
                            Text="Отправить"
                            Command="{Binding SendMessageCommand}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</ContentPage>
